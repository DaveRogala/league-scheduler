@inject IStringLocalizer<CommonStrings> LC
@inject IStringLocalizer<AdminStrings> LA

<MudDialog>
    <DialogContent>
        <MudForm @ref="_form" @bind-IsValid="_isValid">
            <MudTextField @bind-Value="_model.Name"
                          Label="@LA["MatchTypeName"]"
                          Required="true"
                          RequiredError="@LA["MatchTypeNameRequired"]"
                          Immediate="true"
                          Class="mb-3" />
            <MudTextField @bind-Value="_model.Description"
                          Label="@LA["MatchTypeDescription"]"
                          Lines="4"
                          Class="mb-3" />
            <MudNumericField @bind-Value="_model.MinPlayersPerCourt"
                             Label="@LA["MatchTypeMinPlayers"]"
                             Required="true"
                             Min="1" Max="20"
                             Disabled="_model.IsBuiltIn"
                             Class="mb-3" />
            <MudNumericField @bind-Value="_model.MaxPlayersPerCourt"
                             Label="@LA["MatchTypeMaxPlayers"]"
                             Required="true"
                             Min="1" Max="20"
                             Disabled="_model.IsBuiltIn"
                             Class="mb-3" />
            <MudCheckBox @bind-Value="_model.MustHaveEvenPlayers"
                         Label="@LA["MatchTypeMustHaveEvenPlayers"]"
                         Disabled="_model.IsBuiltIn"
                         Class="mb-3" />
            <MudNumericField @bind-Value="_model.SortOrder"
                             Label="@LA["MatchTypeSortOrder"]"
                             Min="0"
                             Class="mb-3" />
            @if (_model.IsBuiltIn)
            {
                <MudText Typo="Typo.caption" Color="Color.Info">@LA["MatchTypeBuiltInNote"]</MudText>
            }
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => MudDialog.Cancel())">@LC["Cancel"]</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled"
                   Disabled="!_isValid" OnClick="Submit">
            @LC["Save"]
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;
    [Parameter] public MatchTypeDto? MatchType { get; set; }

    private MudForm _form = null!;
    private bool _isValid;
    private MatchTypeDto _model = new();

    protected override void OnParametersSet()
    {
        _model = MatchType is not null
            ? new MatchTypeDto
            {
                Id = MatchType.Id,
                Name = MatchType.Name,
                Description = MatchType.Description,
                MinPlayersPerCourt = MatchType.MinPlayersPerCourt,
                MaxPlayersPerCourt = MatchType.MaxPlayersPerCourt,
                MustHaveEvenPlayers = MatchType.MustHaveEvenPlayers,
                IsBuiltIn = MatchType.IsBuiltIn,
                SortOrder = MatchType.SortOrder
            }
            : new MatchTypeDto { SortOrder = 10 };
    }

    private async Task Submit()
    {
        await _form.ValidateAsync();
        if (!_isValid) return;
        MudDialog.Close(DialogResult.Ok(_model));
    }
}
