@page "/login"
@inject AuthClient AuthClient
@inject AppAuthStateProvider AuthState
@inject NavigationManager Nav
@inject IStringLocalizer<AuthStrings> L

<PageTitle>@L["LoginTitle"]</PageTitle>

<MudGrid Justify="Justify.Center">
    <MudItem xs="12" sm="8" md="5" lg="4">
        <MudCard Class="pa-2 mt-8">
            <MudCardHeader>
                <CardHeaderContent>
                    <MudText Typo="Typo.h5">@L["LoginTitle"]</MudText>
                </CardHeaderContent>
            </MudCardHeader>
            <MudCardContent>
                <MudTextField @bind-Value="_email" Label="@L["Email"]" InputType="InputType.Email"
                              Variant="Variant.Outlined" Class="mb-3" />
                <MudTextField @bind-Value="_password" Label="@L["Password"]" InputType="InputType.Password"
                              Variant="Variant.Outlined" />
                @if (_error is not null)
                {
                    <MudAlert Severity="Severity.Error" Class="mt-3">@_error</MudAlert>
                }
            </MudCardContent>
            <MudCardActions Class="px-4 pb-4 flex-column gap-2">
                <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true"
                           OnClick="DoLoginAsync" Disabled="_busy">
                    @if (_busy)
                    {
                        <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                    }
                    @L["SignInButton"]
                </MudButton>
                <MudLink Href="/register" Class="mt-1">@L["RegisterPrompt"]</MudLink>
            </MudCardActions>
        </MudCard>
    </MudItem>
</MudGrid>

@code {
    string _email = string.Empty;
    string _password = string.Empty;
    string? _error;
    bool _busy;

    async Task DoLoginAsync()
    {
        _error = null;
        _busy = true;
        try
        {
            var result = await AuthClient.LoginAsync(new LoginRequestDto
            {
                Email = _email,
                Password = _password
            });

            if (result?.Success == true && result.Token is not null)
            {
                await AuthState.NotifyUserLoggedIn(result.Token);
                Nav.NavigateTo("/");
            }
            else
            {
                _error = result?.Errors.FirstOrDefault() ?? L["InvalidCredentials"];
            }
        }
        finally
        {
            _busy = false;
        }
    }
}
