@inject IStringLocalizer<AddressStrings> L
@inject CountryClient CountryClient

@if (Value is not null)
{
    <MudText Typo="Typo.subtitle1" Class="mb-3">@L["SectionTitle"]</MudText>

    <MudAutocomplete T="CountryDto"
                     Value="_selectedCountryItem"
                     ValueChanged="OnCountryChangedAsync"
                     SearchFunc="SearchCountries"
                     ToStringFunc="c => c?.Name ?? string.Empty"
                     Label="@L["Country"]"
                     Clearable="true"
                     ResetValueOnEmptyText="true"
                     Class="mb-3" />

    <MudTextField @bind-Value="Value.Line1" Label="@L["Line1"]" Class="mb-3" />
    <MudTextField @bind-Value="Value.Line2" Label="@L["Line2"]" Class="mb-3" />
    <MudTextField @bind-Value="Value.Line3" Label="@L["Line3"]" Class="mb-3" />
    <MudTextField @bind-Value="Value.Locality" Label="@L["Locality"]" Class="mb-3" />

    @if (_selectedCountryItem is not null)
    {
        @if (_selectedCountryItem.Region1UseList && _regions.Count > 0)
        {
            <MudAutocomplete T="CountryRegionDto"
                             Value="_selectedRegionItem"
                             ValueChanged="OnAdminAreaChanged"
                             SearchFunc="SearchRegions"
                             ToStringFunc="r => r?.Name ?? string.Empty"
                             Label="@_selectedCountryItem.Region1Name"
                             Clearable="true"
                             ResetValueOnEmptyText="true"
                             Class="mb-3" />
        }
        else
        {
            <MudTextField @bind-Value="Value.AdminArea"
                          Label="@_selectedCountryItem.Region1Name"
                          Class="mb-3" />
        }

        @if (_selectedCountryItem.DisplayRegion2)
        {
            <MudTextField @bind-Value="Value.SubAdminArea"
                          Label="@(_selectedCountryItem.Region2Name ?? L["SubAdminArea"])"
                          Class="mb-3" />
        }
    }

    <MudTextField @bind-Value="Value.PostalCode" Label="@L["PostalCode"]" Class="mb-3" />
}

@code {
    [Parameter] public AddressDto Value { get; set; } = new();

    private List<CountryDto> _countries = [];
    private List<CountryRegionDto> _regions = [];
    private CountryDto? _selectedCountryItem;
    private CountryRegionDto? _selectedRegionItem;

    protected override async Task OnInitializedAsync()
    {
        _countries = await CountryClient.GetAllAsync() ?? [];
        if (Value.CountryId.HasValue)
        {
            _selectedCountryItem = _countries.FirstOrDefault(c => c.Id == Value.CountryId);
            _regions = await CountryClient.GetRegionsAsync(Value.CountryId.Value) ?? [];
            if (Value.AdminAreaId.HasValue)
                _selectedRegionItem = _regions.FirstOrDefault(r => r.Id == Value.AdminAreaId);
        }
    }

    private async Task OnCountryChangedAsync(CountryDto? country)
    {
        _selectedCountryItem = country;
        Value.CountryId = country?.Id;
        Value.AdminAreaId = null;
        Value.AdminArea = null;
        _selectedRegionItem = null;
        _regions = country is not null
            ? await CountryClient.GetRegionsAsync(country.Id) ?? []
            : [];
    }

    private void OnAdminAreaChanged(CountryRegionDto? region)
    {
        _selectedRegionItem = region;
        Value.AdminAreaId = region?.Id;
        Value.AdminArea = region?.Name;
    }

    private Task<IEnumerable<CountryDto>> SearchCountries(string value, CancellationToken ct)
    {
        if (string.IsNullOrWhiteSpace(value))
            return Task.FromResult<IEnumerable<CountryDto>>(_countries);
        return Task.FromResult(
            _countries.Where(c => c.Name.Contains(value, StringComparison.OrdinalIgnoreCase)));
    }

    private Task<IEnumerable<CountryRegionDto>> SearchRegions(string value, CancellationToken ct)
    {
        if (string.IsNullOrWhiteSpace(value))
            return Task.FromResult<IEnumerable<CountryRegionDto>>(_regions);
        return Task.FromResult(
            _regions.Where(r => r.Name.Contains(value, StringComparison.OrdinalIgnoreCase)
                             || r.Code.Contains(value, StringComparison.OrdinalIgnoreCase)));
    }
}
