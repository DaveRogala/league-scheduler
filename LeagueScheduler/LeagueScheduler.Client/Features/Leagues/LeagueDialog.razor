@inject IStringLocalizer<CommonStrings> LC
@inject IStringLocalizer<LeagueStrings> L
@inject LeagueClient LeagueClient
@inject MatchTypeClient MatchTypeClient
@inject ISnackbar Snackbar

<MudDialog>
    <DialogContent>
        <MudForm @ref="_form" @bind-IsValid="_isValid">
            <MudTextField @bind-Value="_model.Name"
                          Label="@L["Name"]"
                          Required="true"
                          RequiredError="@L["NameRequired"]"
                          Immediate="true"
                          Class="mb-3" />
            <MudSelect @bind-Value="_model.Mode" Label="@L["Mode"]" Class="mb-3">
                <MudSelectItem Value="LeagueMode.Recreational">@L["Recreational"]</MudSelectItem>
                <MudSelectItem Value="LeagueMode.Competitive">@L["Competitive"]</MudSelectItem>
            </MudSelect>
            <MudAutocomplete T="MatchTypeDto"
                             Value="_selectedMatchType"
                             ValueChanged="OnMatchTypeChanged"
                             SearchFunc="SearchMatchTypes"
                             ToStringFunc="m => m?.Name ?? string.Empty"
                             Label="@L["MatchType"]"
                             Required="true"
                             RequiredError="@L["MatchTypeRequired"]"
                             Clearable="true"
                             ResetValueOnEmptyText="true"
                             Class="mb-3" />
            <MudCheckBox @bind-Value="_model.RequireApprovalToJoin"
                         Label="@L["RequireApproval"]" />
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => MudDialog.Cancel())">@LC["Cancel"]</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled"
                   Disabled="!_isValid" OnClick="SaveAsync">
            @LC["Save"]
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;
    [Parameter] public LeagueDto? League { get; set; }

    private MudForm _form = null!;
    private bool _isValid;
    private LeagueDto _model = new();
    private List<MatchTypeDto> _matchTypes = [];
    private MatchTypeDto? _selectedMatchType;

    protected override async Task OnInitializedAsync()
    {
        _matchTypes = await MatchTypeClient.GetAllAsync() ?? [];
    }

    protected override void OnParametersSet()
    {
        _model = League is not null
            ? new LeagueDto
            {
                Id = League.Id,
                Name = League.Name,
                Mode = League.Mode,
                MatchTypeId = League.MatchTypeId,
                MatchType = League.MatchType,
                RequireApprovalToJoin = League.RequireApprovalToJoin
            }
            : new LeagueDto();

        _selectedMatchType = _model.MatchTypeId != default
            ? _matchTypes.FirstOrDefault(m => m.Id == _model.MatchTypeId)
            : null;
    }

    private void OnMatchTypeChanged(MatchTypeDto? mt)
    {
        _selectedMatchType = mt;
        _model.MatchTypeId = mt?.Id ?? default;
        _model.MatchType = mt;
    }

    private Task<IEnumerable<MatchTypeDto>> SearchMatchTypes(string value, CancellationToken ct)
    {
        if (string.IsNullOrWhiteSpace(value))
            return Task.FromResult<IEnumerable<MatchTypeDto>>(_matchTypes);
        return Task.FromResult(_matchTypes.Where(m =>
            m.Name.Contains(value, StringComparison.OrdinalIgnoreCase)));
    }

    private async Task SaveAsync()
    {
        await _form.ValidateAsync();
        if (!_isValid) return;

        var response = League is null
            ? await LeagueClient.CreateAsync(_model)
            : await LeagueClient.UpdateAsync(_model.Id, _model);

        if (response.IsSuccessStatusCode)
        {
            Snackbar.Add(L["SaveSuccess"], Severity.Success);
            MudDialog.Close(DialogResult.Ok(true));
        }
        else
        {
            Snackbar.Add(L["SaveError"], Severity.Error);
        }
    }
}
