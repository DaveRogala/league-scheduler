@page "/leagues"
@attribute [Authorize]
@inject IStringLocalizer<CommonStrings> LC
@inject IStringLocalizer<LeagueStrings> L
@inject LeagueClient LeagueClient
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<PageTitle>@L["PageTitle"]</PageTitle>

<MudText Typo="Typo.h4" GutterBottom="true">@L["PageTitle"]</MudText>

<MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-4">
    <MudButton Color="Color.Primary" Variant="Variant.Filled"
               StartIcon="@Icons.Material.Filled.Add"
               OnClick="CreateAsync">
        @L["CreateLeague"]
    </MudButton>
    <MudSpacer />
    <MudTextField @bind-Value="_searchString" Placeholder="@LC["Search"]"
                  Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                  Immediate="true" Clearable="true" Style="max-width:300px" />
</MudStack>

<MudTable Items="@FilteredLeagues" Hover="true" Loading="_loading" Dense="true">
    <HeaderContent>
        <MudTh><MudTableSortLabel SortBy="@(new Func<LeagueDto, object>(x => x.Name))">@L["Name"]</MudTableSortLabel></MudTh>
        <MudTh><MudTableSortLabel SortBy="@(new Func<LeagueDto, object>(x => x.Mode))">@L["Mode"]</MudTableSortLabel></MudTh>
        <MudTh><MudTableSortLabel SortBy="@(new Func<LeagueDto, object>(x => x.MatchType?.Name ?? string.Empty))">@L["MatchType"]</MudTableSortLabel></MudTh>
        <MudTh><MudTableSortLabel SortBy="@(new Func<LeagueDto, object>(x => x.RequireApprovalToJoin))">@L["RequireApproval"]</MudTableSortLabel></MudTh>
        <MudTh></MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd DataLabel="@L["Name"]">@context.Name</MudTd>
        <MudTd DataLabel="@L["Mode"]">@L[context.Mode.ToString()]</MudTd>
        <MudTd DataLabel="@L["MatchType"]">@context.MatchType?.Name</MudTd>
        <MudTd DataLabel="@L["RequireApproval"]">
            @if (context.RequireApprovalToJoin)
            {
                <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" Size="Size.Small" />
            }
            else
            {
                <MudIcon Icon="@Icons.Material.Outlined.Circle" Color="Color.Default" Size="Size.Small" />
            }
        </MudTd>
        <MudTd>
            <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                           title="@LC["Edit"]" OnClick="() => EditAsync(context)" />
            <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small"
                           Color="Color.Error" title="@LC["Delete"]"
                           OnClick="() => DeleteAsync(context)" />
        </MudTd>
    </RowTemplate>
    <NoRecordsContent>
        <MudText Typo="Typo.body2" Class="pa-4">@L["NoLeagues"]</MudText>
    </NoRecordsContent>
</MudTable>

@code {
    private List<LeagueDto> _leagues = [];
    private bool _loading = true;
    private string _searchString = string.Empty;

    private IEnumerable<LeagueDto> FilteredLeagues => string.IsNullOrWhiteSpace(_searchString)
        ? _leagues
        : _leagues.Where(l =>
        {
            var s = _searchString.Trim();
            return l.Name.Contains(s, StringComparison.OrdinalIgnoreCase)
                || l.Mode.ToString().Contains(s, StringComparison.OrdinalIgnoreCase)
                || (l.MatchType?.Name ?? string.Empty).Contains(s, StringComparison.OrdinalIgnoreCase);
        });

    protected override async Task OnInitializedAsync() => await RefreshAsync();

    private async Task RefreshAsync()
    {
        _loading = true;
        _leagues = await LeagueClient.GetAllAsync() ?? [];
        _loading = false;
    }

    private async Task CreateAsync()
    {
        var dialog = await DialogService.ShowAsync<LeagueDialog>(L["CreateLeague"]);
        if (!(await dialog.Result)!.Canceled) await RefreshAsync();
    }

    private async Task EditAsync(LeagueDto league)
    {
        var parameters = new DialogParameters<LeagueDialog> { { x => x.League, league } };
        var dialog = await DialogService.ShowAsync<LeagueDialog>(L["EditLeague"], parameters);
        if (!(await dialog.Result)!.Canceled) await RefreshAsync();
    }

    private async Task DeleteAsync(LeagueDto league)
    {
        var confirmed = await DialogService.ShowMessageBoxAsync(
            LC["Confirm"],
            L["ConfirmDeleteBody"],
            yesText: LC["Delete"],
            cancelText: LC["Cancel"]);

        if (confirmed is not true) return;

        var response = await LeagueClient.DeleteAsync(league.Id);
        Snackbar.Add(
            response.IsSuccessStatusCode ? L["DeleteSuccess"] : L["DeleteError"],
            response.IsSuccessStatusCode ? Severity.Success : Severity.Error);
        if (response.IsSuccessStatusCode) await RefreshAsync();
    }
}
