@page "/scheduler"
@using LeagueScheduler.Shared.Scheduling
@inject SchedulerClient SchedulerClient
@inject IStringLocalizer<SchedulingStrings> L
@inject IStringLocalizer<CommonStrings> LC

<PageTitle>@L["PageTitle"]</PageTitle>

<MudText Typo="Typo.h4">@L["PageTitle"]</MudText>

<MudPaper Class="pa-4">
    <MudText>@L["Instruction"]</MudText>
    <MudTextField @bind-Value="RequestJson" Lines="10" />
    <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="RunSchedule">@L["ComputeButton"]</MudButton>
</MudPaper>

@if (Result != null)
{
    <MudPaper Class="pa-4 mt-4">
        <MudText Typo="Typo.h6" GutterBottom="true">@L["ResultsTitle"]</MudText>

        <MudTextField @bind-Value="_searchString" Placeholder="@LC["Search"]"
                      Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                      Immediate="true" Clearable="true" Class="mb-3" Style="max-width:300px" />

        <MudTable Items="@FilteredMatches" Dense="true" Hover="true">
            <HeaderContent>
                <MudTh><MudTableSortLabel SortBy="@(new Func<MatchDto, object>(x => x.Date))">@L["ColDate"]</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="@(new Func<MatchDto, object>(x => x.CourtName))">@L["ColCourt"]</MudTableSortLabel></MudTh>
                <MudTh>@L["ColPlayers"]</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd>@context.Date.ToShortDateString()</MudTd>
                <MudTd>@context.CourtName</MudTd>
                <MudTd>@string.Join(", ", context.PlayerIds)</MudTd>
            </RowTemplate>
        </MudTable>
    </MudPaper>
}

@code {
    string RequestJson { get; set; } = string.Empty;
    ScheduleResultDto? Result { get; set; }
    private string _searchString = string.Empty;

    private IEnumerable<MatchDto> FilteredMatches => Result is null || string.IsNullOrWhiteSpace(_searchString)
        ? Result?.Matches ?? []
        : Result.Matches.Where(m =>
        {
            var s = _searchString.Trim();
            return m.Date.ToShortDateString().Contains(s, StringComparison.OrdinalIgnoreCase)
                || m.CourtName.Contains(s, StringComparison.OrdinalIgnoreCase);
        });

    async Task RunSchedule()
    {
        _searchString = string.Empty;
        try
        {
            var req = System.Text.Json.JsonSerializer.Deserialize<ScheduleRequestDto>(RequestJson);
            if (req == null) return;
            Result = await SchedulerClient.ComputeAsync(req);
        }
        catch (Exception ex)
        {
            Console.WriteLine(ex.Message);
        }
    }
}
