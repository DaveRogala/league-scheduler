@page "/profile"
@attribute [Authorize]
@inject IStringLocalizer<ProfileStrings> L
@inject IStringLocalizer<CommonStrings> LC
@inject UserProfileClient ProfileClient
@inject PronounsClient PronounsClient
@inject TimeZoneClient TzClient
@inject ISnackbar Snackbar

<PageTitle>@L["PageTitle"]</PageTitle>

<MudText Typo="Typo.h4" GutterBottom="true">@L["PageTitle"]</MudText>

@if (_loading)
{
    <MudProgressCircular Indeterminate="true" />
}
else
{
    <MudForm @ref="_form" @bind-IsValid="_isValid">
        <MudGrid>
            <MudItem xs="12" md="8" lg="6">
                <MudCard>
                    <MudCardContent>
                        <MudText Typo="Typo.subtitle2" Class="mb-3">@L["Email"]: @_model.Email</MudText>

                        <MudTextField @bind-Value="_model.FirstName"
                                      Label="@L["FirstName"]"
                                      Required="true"
                                      RequiredError="@L["FirstNameRequired"]"
                                      Immediate="true"
                                      Class="mb-3" />

                        <MudTextField @bind-Value="_model.MiddleName"
                                      Label="@L["MiddleName"]"
                                      Class="mb-3" />

                        <MudTextField @bind-Value="_model.LastName"
                                      Label="@L["LastName"]"
                                      Required="true"
                                      RequiredError="@L["LastNameRequired"]"
                                      Immediate="true"
                                      Class="mb-3" />

                        <MudTextField @bind-Value="_model.DisplayName"
                                      Label="@L["DisplayName"]"
                                      HelperText="@L["DisplayNameHint"]"
                                      Required="true"
                                      Immediate="true"
                                      Class="mb-3" />

                        <MudSelect @bind-Value="_pronounsValue"
                                   Label="@L["Pronouns"]"
                                   Clearable="true"
                                   Class="mb-3">
                            <MudSelectItem Value="@((string?)null)">@L["PronounsNotSpecified"]</MudSelectItem>
                            @foreach (var p in _availablePronouns)
                            {
                                <MudSelectItem Value="@p.Id.ToString()">@p.Label</MudSelectItem>
                            }
                            <MudSelectItem Value="@("other")">@L["PronounsSelfDescribe"]</MudSelectItem>
                        </MudSelect>

                        @if (_pronounsValue == "other")
                        {
                            <MudTextField @bind-Value="_model.PronounsCustom"
                                          Label="@L["PronounsCustom"]"
                                          Immediate="true"
                                          Class="mb-3" />
                        }

                        <MudSelect @bind-Value="_model.PreferredTimeZone"
                                   Label="@L["PreferredTimeZone"]"
                                   Clearable="true"
                                   Class="mb-3">
                            <MudSelectItem Value="@((string?)null)">—</MudSelectItem>
                            @foreach (var tz in _timeZones)
                            {
                                <MudSelectItem Value="@tz.Id">@FormatTz(tz)</MudSelectItem>
                            }
                        </MudSelect>
                    </MudCardContent>
                    <MudCardActions Class="px-4 pb-4">
                        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                                   Disabled="!_isValid || _saving"
                                   OnClick="SaveAsync">
                            @if (_saving)
                            {
                                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                            }
                            @LC["Save"]
                        </MudButton>
                    </MudCardActions>
                </MudCard>
            </MudItem>
        </MudGrid>
    </MudForm>
}

@code {
    private MudForm _form = null!;
    private bool _isValid;
    private bool _loading = true;
    private bool _saving;
    private UserProfileModel _model = new();
    private List<SupportedPronounsDto> _availablePronouns = [];
    private List<SupportedTimeZoneDto> _timeZones = [];

    // null = not specified, "other" = self-describe, Guid.ToString() = selected set
    private string? _pronounsValue;

    protected override async Task OnInitializedAsync()
    {
        var tzTask = TzClient.GetEnabledAsync();
        var pronounsTask = PronounsClient.GetAllAsync();
        var dto = await ProfileClient.GetAsync();

        if (dto is not null)
        {
            _model = new UserProfileModel
            {
                Email = dto.Email,
                FirstName = dto.FirstName,
                MiddleName = dto.MiddleName,
                LastName = dto.LastName,
                DisplayName = dto.DisplayName,
                PronounsCustom = dto.PronounsCustom,
                PreferredTimeZone = dto.PreferredTimeZone
            };

            if (dto.PronounsId.HasValue)
                _pronounsValue = dto.PronounsId.Value.ToString();
            else if (!string.IsNullOrWhiteSpace(dto.PronounsCustom))
                _pronounsValue = "other";
            else
                _pronounsValue = null;
        }

        _availablePronouns = await pronounsTask ?? [];
        _timeZones = await tzTask ?? [];
        _loading = false;
    }

    private async Task SaveAsync()
    {
        await _form.ValidateAsync();
        if (!_isValid) return;

        _saving = true;
        try
        {
            Guid? pronounsId = _pronounsValue is null or "" or "other"
                ? null
                : Guid.TryParse(_pronounsValue, out var g) ? g : null;

            string? pronounsCustom = _pronounsValue == "other"
                ? _model.PronounsCustom?.Trim()
                : null;

            var response = await ProfileClient.UpdateAsync(new UserProfileDto
            {
                Email = _model.Email,
                FirstName = _model.FirstName,
                MiddleName = _model.MiddleName,
                LastName = _model.LastName,
                DisplayName = _model.DisplayName,
                PronounsId = pronounsId,
                PronounsCustom = pronounsCustom,
                PreferredTimeZone = _model.PreferredTimeZone
            });

            Snackbar.Add(
                response.IsSuccessStatusCode ? L["SaveSuccess"] : L["SaveError"],
                response.IsSuccessStatusCode ? Severity.Success : Severity.Error);
        }
        finally
        {
            _saving = false;
        }
    }

    private static string FormatTz(SupportedTimeZoneDto tz)
    {
        var h = (int)Math.Truncate(tz.UtcOffsetHours);
        var m = (int)Math.Abs((tz.UtcOffsetHours - h) * 60);
        var offset = m == 0 ? $"UTC{h:+0;-0;+0}" : $"UTC{h:+0;-0;+0}:{m:00}";
        return $"({offset}) {tz.DisplayName}";
    }

    private class UserProfileModel
    {
        public string Email { get; set; } = string.Empty;
        public string FirstName { get; set; } = string.Empty;
        public string? MiddleName { get; set; }
        public string LastName { get; set; } = string.Empty;
        public string DisplayName { get; set; } = string.Empty;
        public string? PronounsCustom { get; set; }
        public string? PreferredTimeZone { get; set; }
    }
}
