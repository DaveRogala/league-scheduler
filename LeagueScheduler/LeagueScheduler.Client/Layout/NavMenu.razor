@inject IStringLocalizer<CommonStrings> L
@inject IStringLocalizer<AdminStrings> LA

<MudNavMenu>
    <MudNavLink Href="" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Home">@L["NavHome"]</MudNavLink>
    <MudNavLink Href="leagues" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.SportsTennis">@L["NavLeagues"]</MudNavLink>
    <MudNavLink Href="courts" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Place">@L["NavCourts"]</MudNavLink>
    <MudNavLink Href="scheduler" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.DateRange">@L["NavScheduler"]</MudNavLink>
    <MudDivider Class="my-2" />
    <AuthorizeView>
        <Authorized>
            <MudNavGroup Title="@LA["NavAdmin"]" Icon="@Icons.Material.Filled.AdminPanelSettings" Expanded="false">
                <MudNavLink Href="admin/timezones" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Schedule">@LA["TimeZonesPageTitle"]</MudNavLink>
                <MudNavLink Href="admin/pronouns" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.RecordVoiceOver">@LA["PronounsNavLink"]</MudNavLink>
                <MudNavLink Href="admin/countries" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Public">@LA["CountriesNavLink"]</MudNavLink>
                <MudNavLink Href="admin/logs" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.ListAlt">@LA["LogsNavLink"]</MudNavLink>
            </MudNavGroup>
        </Authorized>
    </AuthorizeView>
</MudNavMenu>
